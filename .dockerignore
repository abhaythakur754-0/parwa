# ════════════════════════════════════════════════════════════════
# PARWA .dockerignore
# Files to exclude from Docker build context
# ════════════════════════════════════════════════════════════════

# Version control
.git
.gitignore
.gitattributes

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
*.egg-info
.eggs
*.egg
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov/
.tox/
.nox/

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Node.js / Frontend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next/
out/
.nuxt/
.cache/
dist/
frontend/node_modules/
frontend/.next/
frontend/dist/

# Testing
tests/
.pytest_cache/
coverage/
.nyc_output/

# Documentation
docs/
*.md
!README.md

# Docker
Dockerfile*
docker-compose*
.docker/
.dockerignore

# Kubernetes
infra/k8s/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Build artifacts
*.log
*.tmp
*.temp
*.bak
*.backup

# OS files
.DS_Store
Thumbs.db
ehthumbs.db

# Environment files
.env
.env.*
!.env.example

# Local development
*.local
docker-compose.override.yml

# Parwa specific
parwa/
skills/
download/
agent-ctx/
worklog.md
