{
  "dashboard": {
    "title": "Client Success Dashboard",
    "uid": "client-success",
    "tags": ["client-success", "parwa", "week24"],
    "timezone": "browser",
    "refresh": "5m",
    "time": {
      "from": "now-7d",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Overall Client Health Score",
        "type": "gauge",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 8,
          "h": 6
        },
        "targets": [
          {
            "expr": "avg(client_health_score)",
            "legendFormat": "Average Health",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 60},
                {"color": "green", "value": 80}
              ]
            }
          }
        },
        "description": "Average health score across all 10 clients"
      },
      {
        "id": 2,
        "title": "Churn Risk Overview",
        "type": "piechart",
        "gridPos": {
          "x": 8,
          "y": 0,
          "w": 8,
          "h": 6
        },
        "targets": [
          {
            "expr": "count(client_churn_risk{level=\"low\"})",
            "legendFormat": "Low Risk",
            "refId": "A"
          },
          {
            "expr": "count(client_churn_risk{level=\"medium\"})",
            "legendFormat": "Medium Risk",
            "refId": "B"
          },
          {
            "expr": "count(client_churn_risk{level=\"high\"})",
            "legendFormat": "High Risk",
            "refId": "C"
          },
          {
            "expr": "count(client_churn_risk{level=\"critical\"})",
            "legendFormat": "Critical Risk",
            "refId": "D"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right"
          }
        },
        "description": "Distribution of clients by churn risk level"
      },
      {
        "id": 3,
        "title": "At-Risk Clients",
        "type": "stat",
        "gridPos": {
          "x": 16,
          "y": 0,
          "w": 8,
          "h": 3
        },
        "targets": [
          {
            "expr": "count(client_churn_probability > 0.4)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 2},
                {"color": "red", "value": 4}
              ]
            }
          }
        },
        "description": "Number of clients with churn probability > 40%"
      },
      {
        "id": 4,
        "title": "Healthy Clients",
        "type": "stat",
        "gridPos": {
          "x": 16,
          "y": 3,
          "w": 8,
          "h": 3
        },
        "targets": [
          {
            "expr": "count(client_health_score >= 80)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 5},
                {"color": "green", "value": 7}
              ]
            }
          }
        },
        "description": "Number of clients with health score >= 80"
      },
      {
        "id": 5,
        "title": "Health Score by Client",
        "type": "bargauge",
        "gridPos": {
          "x": 0,
          "y": 6,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "client_health_score{client_id=~\"client_0.*\"}",
            "legendFormat": "{{client_id}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 60},
                {"color": "green", "value": 80}
              ]
            }
          }
        },
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient"
        },
        "description": "Individual health scores for all 10 clients"
      },
      {
        "id": 6,
        "title": "Onboarding Progress",
        "type": "bargauge",
        "gridPos": {
          "x": 12,
          "y": 6,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "client_onboarding_completion{client_id=~\"client_0.*\"}",
            "legendFormat": "{{client_id}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "unit": "percent"
          }
        },
        "description": "Onboarding completion percentage by client"
      },
      {
        "id": 7,
        "title": "Health Score Trend (7 Days)",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 14,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "avg(client_health_score)",
            "legendFormat": "Average Health",
            "refId": "A"
          },
          {
            "expr": "avg(client_health_score) - stddev(client_health_score)",
            "legendFormat": "Lower Bound",
            "refId": "B"
          },
          {
            "expr": "avg(client_health_score) + stddev(client_health_score)",
            "legendFormat": "Upper Bound",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        },
        "description": "Health score trend over the past 7 days"
      },
      {
        "id": 8,
        "title": "Churn Probability Trend",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 14,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "avg(client_churn_probability) * 100",
            "legendFormat": "Average Churn Risk %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "lineWidth": 2
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 30},
                {"color": "red", "value": 50}
              ]
            }
          }
        },
        "description": "Churn probability trend over time"
      },
      {
        "id": 9,
        "title": "Engagement Score",
        "type": "gauge",
        "gridPos": {
          "x": 0,
          "y": 22,
          "w": 6,
          "h": 6
        },
        "targets": [
          {
            "expr": "avg(client_engagement_score)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 50},
                {"color": "green", "value": 70}
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Average Response Time",
        "type": "gauge",
        "gridPos": {
          "x": 6,
          "y": 22,
          "w": 6,
          "h": 6
        },
        "targets": [
          {
            "expr": "avg(client_response_time_hours)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 8,
            "unit": "h",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 3},
                {"color": "red", "value": 5}
              ]
            }
          }
        },
        "description": "Average response time in hours (target: <4h)"
      },
      {
        "id": 11,
        "title": "Accuracy Rate",
        "type": "gauge",
        "gridPos": {
          "x": 12,
          "y": 22,
          "w": 6,
          "h": 6
        },
        "targets": [
          {
            "expr": "avg(client_accuracy_rate)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 75},
                {"color": "green", "value": 85}
              ]
            }
          }
        },
        "description": "AI accuracy rate (target: >85%)"
      },
      {
        "id": 12,
        "title": "Resolution Rate",
        "type": "gauge",
        "gridPos": {
          "x": 18,
          "y": 22,
          "w": 6,
          "h": 6
        },
        "targets": [
          {
            "expr": "avg(client_resolution_rate)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "green", "value": 85}
              ]
            }
          }
        }
      },
      {
        "id": 13,
        "title": "Intervention Activity",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 28,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "increase(interventions_sent_total[1h])",
            "legendFormat": "Interventions/Hour",
            "refId": "A"
          },
          {
            "expr": "increase(interventions_successful_total[1h])",
            "legendFormat": "Successful",
            "refId": "B"
          }
        ],
        "description": "Intervention activity over time"
      },
      {
        "id": 14,
        "title": "Communication Activity",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 28,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "increase(messages_sent_total[1h])",
            "legendFormat": "Messages Sent",
            "refId": "A"
          },
          {
            "expr": "increase(messages_read_total[1h])",
            "legendFormat": "Messages Read",
            "refId": "B"
          }
        ],
        "description": "Communication activity metrics"
      },
      {
        "id": 15,
        "title": "Client Details Table",
        "type": "table",
        "gridPos": {
          "x": 0,
          "y": 36,
          "w": 24,
          "h": 10
        },
        "targets": [
          {
            "expr": "client_health_score{client_id=~\"client_0.*\"}",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true, "__name__": true},
              "indexByName": {"client_id": 0, "Value": 1}
            }
          }
        ],
        "description": "Detailed client metrics table"
      }
    ],
    "schemaVersion": 38,
    "version": 1
  }
}
