{
  "dashboard": {
    "title": "PARWA SLA Dashboard",
    "uid": "parwa-sla",
    "tags": ["parwa", "sla", "performance"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "SLA Compliance Percentage",
        "type": "gauge",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_sla_compliance_percentage",
            "legendFormat": "Compliance",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 90},
                {"color": "green", "value": 95}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "SLA Breach Count",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_sla_breaches_total",
            "legendFormat": "Total Breaches",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Avg Time to Resolution",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_resolution_time_seconds_avg / 3600",
            "legendFormat": "Hours",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "h"
          }
        }
      },
      {
        "id": 4,
        "title": "Response Time by Priority",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(parwa_response_time_seconds_bucket{priority=\"critical\"}[5m]))",
            "legendFormat": "Critical P95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(parwa_response_time_seconds_bucket{priority=\"high\"}[5m]))",
            "legendFormat": "High P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.95, rate(parwa_response_time_seconds_bucket{priority=\"medium\"}[5m]))",
            "legendFormat": "Medium P95",
            "refId": "C"
          },
          {
            "expr": "histogram_quantile(0.95, rate(parwa_response_time_seconds_bucket{priority=\"low\"}[5m]))",
            "legendFormat": "Low P95",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 5,
        "title": "Escalation Phase Distribution",
        "type": "piechart",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_escalation_phase_tickets{phase=\"1\"}",
            "legendFormat": "Phase 1 (24h)",
            "refId": "A"
          },
          {
            "expr": "parwa_escalation_phase_tickets{phase=\"2\"}",
            "legendFormat": "Phase 2 (48h)",
            "refId": "B"
          },
          {
            "expr": "parwa_escalation_phase_tickets{phase=\"3\"}",
            "legendFormat": "Phase 3 (72h)",
            "refId": "C"
          },
          {
            "expr": "parwa_escalation_phase_tickets{phase=\"4\"}",
            "legendFormat": "Phase 4 (96h)",
            "refId": "D"
          }
        ]
      },
      {
        "id": 6,
        "title": "SLA Breaches Over Time",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 16
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(parwa_sla_breaches_total[1h])",
            "legendFormat": "Breaches/hr",
            "refId": "A"
          }
        ]
      },
      {
        "id": 7,
        "title": "Resolution Time Distribution",
        "type": "histogram",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 16
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(parwa_resolution_time_seconds_bucket[5m])",
            "legendFormat": "{{le}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 8,
        "title": "SLA by Industry",
        "type": "bar",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 24
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_sla_compliance_percentage{industry=\"ecommerce\"}",
            "legendFormat": "E-commerce",
            "refId": "A"
          },
          {
            "expr": "parwa_sla_compliance_percentage{industry=\"saas\"}",
            "legendFormat": "SaaS",
            "refId": "B"
          },
          {
            "expr": "parwa_sla_compliance_percentage{industry=\"healthcare\"}",
            "legendFormat": "Healthcare",
            "refId": "C"
          },
          {
            "expr": "parwa_sla_compliance_percentage{industry=\"logistics\"}",
            "legendFormat": "Logistics",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        }
      },
      {
        "id": 9,
        "title": "Active Escalations",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 24
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_escalations_active",
            "legendFormat": "Active",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 10,
        "title": "Escalations Resolved",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 24
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_escalations_resolved_total",
            "legendFormat": "Resolved",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background"
        }
      },
      {
        "id": 11,
        "title": "First Response Time",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 32
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(parwa_first_response_time_seconds_bucket[5m]))",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(parwa_first_response_time_seconds_bucket[5m]))",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(parwa_first_response_time_seconds_bucket[5m]))",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      }
    ],
    "schemaVersion": 38,
    "version": 1
  },
  "overwrite": true
}
