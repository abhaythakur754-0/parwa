{
  "dashboard": {
    "title": "PARWA MCP Servers Dashboard",
    "uid": "parwa-mcp",
    "tags": ["parwa", "mcp", "servers"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "MCP Server Status Overview",
        "type": "stat",
        "gridPos": {
          "h": 6,
          "w": 24,
          "x": 0,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "up{job=\"mcp-knowledge\"}",
            "legendFormat": "Knowledge",
            "refId": "A"
          },
          {
            "expr": "up{job=\"mcp-integration\"}",
            "legendFormat": "Integration",
            "refId": "B"
          },
          {
            "expr": "up{job=\"mcp-analytics\"}",
            "legendFormat": "Analytics",
            "refId": "C"
          },
          {
            "expr": "up{job=\"mcp-notification\"}",
            "legendFormat": "Notification",
            "refId": "D"
          },
          {
            "expr": "up{job=\"mcp-guardrails\"}",
            "legendFormat": "Guardrails",
            "refId": "E"
          },
          {
            "expr": "up{job=\"mcp-compliance\"}",
            "legendFormat": "Compliance",
            "refId": "F"
          },
          {
            "expr": "up{job=\"mcp-escalation\"}",
            "legendFormat": "Escalation",
            "refId": "G"
          },
          {
            "expr": "up{job=\"mcp-voice\"}",
            "legendFormat": "Voice",
            "refId": "H"
          },
          {
            "expr": "up{job=\"mcp-training\"}",
            "legendFormat": "Training",
            "refId": "I"
          },
          {
            "expr": "up{job=\"mcp-billing\"}",
            "legendFormat": "Billing",
            "refId": "J"
          },
          {
            "expr": "up{job=\"mcp-quality\"}",
            "legendFormat": "Quality",
            "refId": "K"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "orientation": "horizontal"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": {"text": "DOWN", "color": "red"},
                  "1": {"text": "UP", "color": "green"}
                }
              }
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "MCP Response Times",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 6
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(mcp_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{server}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 3,
        "title": "MCP Error Rates",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 6
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(mcp_requests_total{status=\"error\"}[5m]) / rate(mcp_requests_total[5m]) * 100",
            "legendFormat": "{{server}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        }
      },
      {
        "id": 4,
        "title": "Knowledge Server Query Volume",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 14
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(mcp_knowledge_queries_total[5m])",
            "legendFormat": "Queries/sec",
            "refId": "A"
          },
          {
            "expr": "rate(mcp_knowledge_cache_hits_total[5m])",
            "legendFormat": "Cache Hits/sec",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        }
      },
      {
        "id": 5,
        "title": "Integration Server Call Volume",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 14
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(mcp_integration_calls_total[5m])",
            "legendFormat": "{{integration_type}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        }
      },
      {
        "id": 6,
        "title": "Guardrails Block Rate",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 22
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(mcp_guardrails_blocked_total[5m])",
            "legendFormat": "{{block_reason}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        }
      },
      {
        "id": 7,
        "title": "Compliance Check Volume",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 22
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(mcp_compliance_checks_total[5m])",
            "legendFormat": "{{check_type}}",
            "refId": "A"
          },
          {
            "expr": "rate(mcp_compliance_violations_total[5m])",
            "legendFormat": "Violations",
            "refId": "B"
          }
        ]
      },
      {
        "id": 8,
        "title": "Voice Server Call Metrics",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 30
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "mcp_voice_active_calls",
            "legendFormat": "Active Calls",
            "refId": "A"
          },
          {
            "expr": "rate(mcp_voice_call_duration_seconds_sum[5m])",
            "legendFormat": "Call Duration",
            "refId": "B"
          }
        ]
      },
      {
        "id": 9,
        "title": "Quality Server Scores",
        "type": "gauge",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 30
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "avg(mcp_quality_accuracy_score)",
            "legendFormat": "Accuracy",
            "refId": "A"
          },
          {
            "expr": "avg(mcp_quality_empathy_score)",
            "legendFormat": "Empathy",
            "refId": "B"
          },
          {
            "expr": "avg(mcp_quality_efficiency_score)",
            "legendFormat": "Efficiency",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "green", "value": 85}
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Request Distribution by Server",
        "type": "piechart",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 38
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "sum by (server) (rate(mcp_requests_total[5m]))",
            "legendFormat": "{{server}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 11,
        "title": "Billing Server Operations",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 38
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(mcp_billing_operations_total[5m])",
            "legendFormat": "{{operation}}",
            "refId": "A"
          }
        ]
      }
    ],
    "schemaVersion": 38,
    "version": 1
  },
  "overwrite": true
}
