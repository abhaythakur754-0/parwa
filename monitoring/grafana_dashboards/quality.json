{
  "dashboard": {
    "title": "PARWA Quality Coach Dashboard",
    "uid": "parwa-quality",
    "tags": ["parwa", "quality", "coach", "scoring"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Average Quality Scores",
        "type": "gauge",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "avg(parwa_quality_accuracy_score)",
            "legendFormat": "Accuracy",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "green", "value": 85}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Average Empathy Score",
        "type": "gauge",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "avg(parwa_quality_empathy_score)",
            "legendFormat": "Empathy",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "green", "value": 85}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Average Efficiency Score",
        "type": "gauge",
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "avg(parwa_quality_efficiency_score)",
            "legendFormat": "Efficiency",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "green", "value": 85}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Quality Trend Over Time",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 8
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "avg_over_time(parwa_quality_accuracy_score[1h])",
            "legendFormat": "Accuracy",
            "refId": "A"
          },
          {
            "expr": "avg_over_time(parwa_quality_empathy_score[1h])",
            "legendFormat": "Empathy",
            "refId": "B"
          },
          {
            "expr": "avg_over_time(parwa_quality_efficiency_score[1h])",
            "legendFormat": "Efficiency",
            "refId": "C"
          },
          {
            "expr": "avg_over_time(parwa_quality_overall_score[1h])",
            "legendFormat": "Overall",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        }
      },
      {
        "id": 5,
        "title": "Low Quality Alert Count",
        "type": "stat",
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 0,
          "y": 16
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_quality_low_score_alerts_total",
            "legendFormat": "Low Quality Alerts",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Conversations Scored",
        "type": "stat",
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 8,
          "y": 16
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_quality_conversations_scored_total",
            "legendFormat": "Total Scored",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area"
        }
      },
      {
        "id": 7,
        "title": "Weekly Reports Generated",
        "type": "stat",
        "gridPos": {
          "h": 6,
          "w": 8,
          "x": 16,
          "y": 16
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_quality_weekly_reports_total",
            "legendFormat": "Reports",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area"
        }
      },
      {
        "id": 8,
        "title": "Quality by Category",
        "type": "bar",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 22
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "avg(parwa_quality_accuracy_score{category=\"refund\"})",
            "legendFormat": "Refund",
            "refId": "A"
          },
          {
            "expr": "avg(parwa_quality_accuracy_score{category=\"faq\"})",
            "legendFormat": "FAQ",
            "refId": "B"
          },
          {
            "expr": "avg(parwa_quality_accuracy_score{category=\"escalation\"})",
            "legendFormat": "Escalation",
            "refId": "C"
          },
          {
            "expr": "avg(parwa_quality_accuracy_score{category=\"general\"})",
            "legendFormat": "General",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        }
      },
      {
        "id": 9,
        "title": "Agent Performance Comparison",
        "type": "table",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 22
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_quality_agent_score",
            "legendFormat": "{{agent_id}}",
            "format": "table",
            "refId": "A"
          }
        ]
      },
      {
        "id": 10,
        "title": "Quality Score Distribution",
        "type": "histogram",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 30
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(parwa_quality_overall_score_bucket[5m])",
            "legendFormat": "{{le}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent"
          }
        }
      },
      {
        "id": 11,
        "title": "Recommendations Generated",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 30
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(parwa_quality_recommendations_total[5m])",
            "legendFormat": "{{recommendation_type}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 12,
        "title": "Manager Notifications",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 38
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(parwa_quality_manager_notifications_total[5m])",
            "legendFormat": "Notifications/min",
            "refId": "A"
          }
        ]
      }
    ],
    "schemaVersion": 38,
    "version": 1
  },
  "overwrite": true
}
