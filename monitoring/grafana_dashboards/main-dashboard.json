{
  "dashboard": {
    "title": "PARWA Main Dashboard",
    "uid": "parwa-main",
    "tags": ["parwa", "main", "overview"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{method}} {{endpoint}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        },
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        }
      },
      {
        "id": 2,
        "title": "Error Rate",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m]) * 100",
            "legendFormat": "Error Rate %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "P95 Latency",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "P95 Latency",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.3},
                {"color": "red", "value": 0.5}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Active Agents by Variant",
        "type": "piechart",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_agents_active{variant=\"mini\"}",
            "legendFormat": "Mini",
            "refId": "A"
          },
          {
            "expr": "parwa_agents_active{variant=\"junior\"}",
            "legendFormat": "PARWA Junior",
            "refId": "B"
          },
          {
            "expr": "parwa_agents_active{variant=\"high\"}",
            "legendFormat": "PARWA High",
            "refId": "C"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right"
          },
          "pieType": "pie"
        }
      },
      {
        "id": 5,
        "title": "Ticket Volume",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 16
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_tickets_total",
            "legendFormat": "Total Tickets",
            "refId": "A"
          },
          {
            "expr": "parwa_tickets_resolved_total",
            "legendFormat": "Resolved",
            "refId": "B"
          },
          {
            "expr": "parwa_tickets_open",
            "legendFormat": "Open",
            "refId": "C"
          }
        ]
      },
      {
        "id": 6,
        "title": "Resolution Rate",
        "type": "gauge",
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 16
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_tickets_resolved_total / parwa_tickets_total * 100",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "green", "value": 90}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Refund Processing Status",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 16
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_refunds_pending",
            "legendFormat": "Pending",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area"
        }
      },
      {
        "id": 8,
        "title": "Refunds Processed Today",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 20
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "increase(parwa_refunds_processed_total[24h])",
            "legendFormat": "Processed",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area"
        }
      },
      {
        "id": 9,
        "title": "Approval Queue Depth",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 24
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_approval_queue_pending",
            "legendFormat": "Pending Approvals",
            "refId": "A"
          },
          {
            "expr": "parwa_approval_queue_in_review",
            "legendFormat": "In Review",
            "refId": "B"
          }
        ]
      },
      {
        "id": 10,
        "title": "System Health",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 24
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "up{job=\"parwa-api\"}",
            "legendFormat": "API",
            "refId": "A"
          },
          {
            "expr": "up{job=\"parwa-workers\"}",
            "legendFormat": "Workers",
            "refId": "B"
          },
          {
            "expr": "up{job=\"parwa-mcp\"}",
            "legendFormat": "MCP",
            "refId": "C"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": {"text": "DOWN", "color": "red"},
                  "1": {"text": "UP", "color": "green"}
                }
              }
            ]
          }
        }
      }
    ],
    "schemaVersion": 38,
    "version": 1
  },
  "overwrite": true
}
