{
  "dashboard": {
    "title": "PARWA Compliance Dashboard",
    "uid": "parwa-compliance",
    "tags": ["parwa", "compliance", "gdpr", "hipaa"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "GDPR Request Count",
        "type": "stat",
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 0,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_gdpr_requests_total",
            "legendFormat": "Total",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area"
        }
      },
      {
        "id": 2,
        "title": "GDPR Requests by Type",
        "type": "piechart",
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 6,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "sum by (request_type) (parwa_gdpr_requests_total)",
            "legendFormat": "{{request_type}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "PII Access Audit Trail",
        "type": "timeseries",
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 12,
          "y": 0
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(parwa_pii_access_total[5m])",
            "legendFormat": "{{access_type}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        }
      },
      {
        "id": 4,
        "title": "Healthcare BAA Status",
        "type": "stat",
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 0,
          "y": 6
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_healthcare_baa_active",
            "legendFormat": "Active BAAs",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "HIPAA Compliance Score",
        "type": "gauge",
        "gridPos": {
          "h": 6,
          "w": 6,
          "x": 6,
          "y": 6
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_hipaa_compliance_score",
            "legendFormat": "Compliance",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 70},
                {"color": "green", "value": 90}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Compliance Violations",
        "type": "timeseries",
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 12,
          "y": 6
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(parwa_compliance_violations_total[5m])",
            "legendFormat": "{{violation_type}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        }
      },
      {
        "id": 7,
        "title": "Data Retention Status",
        "type": "table",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 12
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_data_retention_days",
            "legendFormat": "{{data_type}}",
            "format": "table",
            "refId": "A"
          }
        ]
      },
      {
        "id": 8,
        "title": "PHI Access Events",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 12
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(parwa_phi_access_total[5m])",
            "legendFormat": "{{access_type}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        }
      },
      {
        "id": 9,
        "title": "GDPR Erasure Requests",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 20
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_gdpr_erasure_pending",
            "legendFormat": "Pending",
            "refId": "A"
          },
          {
            "expr": "parwa_gdpr_erasure_completed_total",
            "legendFormat": "Completed",
            "refId": "B"
          }
        ]
      },
      {
        "id": 10,
        "title": "Consent Status",
        "type": "piechart",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 20
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "parwa_consent_given_total",
            "legendFormat": "Given",
            "refId": "A"
          },
          {
            "expr": "parwa_consent_withdrawn_total",
            "legendFormat": "Withdrawn",
            "refId": "B"
          }
        ]
      },
      {
        "id": 11,
        "title": "Audit Trail Events",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 28
        },
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "targets": [
          {
            "expr": "rate(parwa_audit_trail_events_total[5m])",
            "legendFormat": "{{event_type}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        }
      }
    ],
    "schemaVersion": 38,
    "version": 1
  },
  "overwrite": true
}
