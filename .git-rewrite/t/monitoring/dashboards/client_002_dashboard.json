{
  "dashboard": {
    "title": "Client 002 - TechStart SaaS",
    "uid": "client_002_dashboard",
    "tags": ["parwa", "client_002", "saas"],
    "timezone": "America/Los_Angeles",
    "refresh": "30s"
  },
  "panels": [
    {
      "title": "Ticket Volume",
      "type": "graph",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum(rate(parwa_tickets_total{client_id=\"client_002\"}[5m]))", "legendFormat": "Tickets/min"}
      ],
      "yaxes": [{"format": "short"}]
    },
    {
      "title": "Resolution Time",
      "type": "graph",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(parwa_resolution_time_seconds_bucket{client_id=\"client_002\"}[5m]))", "legendFormat": "P95"}
      ],
      "yaxes": [{"format": "s"}]
    },
    {
      "title": "CSAT Score",
      "type": "gauge",
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 6},
      "targets": [
        {"expr": "avg(parwa_csat_score{client_id=\"client_002\"})", "legendFormat": "CSAT"}
      ],
      "thresholds": [{"color": "red", "value": 0}, {"color": "yellow", "value": 3}, {"color": "green", "value": 4}],
      "max": 5
    },
    {
      "title": "Agent Accuracy",
      "type": "stat",
      "gridPos": {"x": 6, "y": 8, "w": 6, "h": 6},
      "targets": [
        {"expr": "avg(parwa_agent_accuracy{client_id=\"client_002\"}) * 100", "legendFormat": "Accuracy %"}
      ],
      "unit": "percent"
    },
    {
      "title": "API Usage",
      "type": "graph",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 6},
      "targets": [
        {"expr": "sum(rate(api_requests_total{client_id=\"client_002\"}[5m]))", "legendFormat": "Requests/sec"},
        {"expr": "sum(rate(api_errors_total{client_id=\"client_002\"}[5m]))", "legendFormat": "Errors/sec"}
      ]
    },
    {
      "title": "Tier Distribution",
      "type": "piechart",
      "gridPos": {"x": 0, "y": 14, "w": 8, "h": 6},
      "targets": [
        {"expr": "count(tickets_by_tier{client_id=\"client_002\", tier=\"free\"})", "legendFormat": "Free"},
        {"expr": "count(tickets_by_tier{client_id=\"client_002\", tier=\"pro\"})", "legendFormat": "Pro"},
        {"expr": "count(tickets_by_tier{client_id=\"client_002\", tier=\"enterprise\"})", "legendFormat": "Enterprise"}
      ]
    },
    {
      "title": "Escalation Rate",
      "type": "stat",
      "gridPos": {"x": 8, "y": 14, "w": 4, "h": 6},
      "targets": [
        {"expr": "sum(rate(parwa_escalations_total{client_id=\"client_002\"}[1h])) / sum(rate(parwa_tickets_total{client_id=\"client_002\"}[1h])) * 100", "legendFormat": "%"}
      ],
      "unit": "percent"
    },
    {
      "title": "Integration Health",
      "type": "table",
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 6},
      "targets": [
        {"expr": "integration_status{client_id=\"client_002\"}", "format": "table"}
      ]
    }
  ],
  "annotations": {
    "list": [
      {"name": "Deployments", "datasource": "-- Grafana --", "enable": true},
      {"name": "Incidents", "datasource": "-- Grafana --", "enable": true}
    ]
  }
}
