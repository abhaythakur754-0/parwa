{
  "dashboard": {
    "title": "PARWA Multi-Client Analytics Dashboard",
    "uid": "parwa-multi-client",
    "tags": ["parwa", "multi-tenant", "analytics"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {"id": 1, "title": "Total Tickets All Clients", "type": "stat", "targets": [{"expr": "sum(parwa_tickets_total)"}]},
      {"id": 2, "title": "Overall Accuracy", "type": "gauge", "targets": [{"expr": "avg(parwa_accuracy_percent)"}]},
      {"id": 3, "title": "P95 Response Time", "type": "stat", "targets": [{"expr": "histogram_quantile(0.95, rate(parwa_response_time_bucket[5m]))"}]},
      {"id": 4, "title": "Collective Intelligence Impact", "type": "gauge", "targets": [{"expr": "parwa_ci_improvement"}]},
      {"id": 5, "title": "Client 001 - Ticket Volume", "type": "timeseries", "targets": [{"expr": "parwa_tickets_total{client_id=\"client_001\"}"}]},
      {"id": 6, "title": "Client 001 - Accuracy", "type": "timeseries", "targets": [{"expr": "parwa_accuracy_percent{client_id=\"client_001\"}"}]},
      {"id": 7, "title": "Client 002 - Ticket Volume", "type": "timeseries", "targets": [{"expr": "parwa_tickets_total{client_id=\"client_002\"}"}]},
      {"id": 8, "title": "Client 002 - Accuracy", "type": "timeseries", "targets": [{"expr": "parwa_accuracy_percent{client_id=\"client_002\"}"}]},
      {"id": 9, "title": "Client 003 - PHI Isolation Status", "type": "stat", "targets": [{"expr": "parwa_phi_isolation{client_id=\"client_003\"}"}]},
      {"id": 10, "title": "Client 003 - HIPAA Compliance", "type": "stat", "targets": [{"expr": "parwa_hipaa_score{client_id=\"client_003\"}"}]},
      {"id": 11, "title": "Client 004 - Ticket Volume", "type": "timeseries", "targets": [{"expr": "parwa_tickets_total{client_id=\"client_004\"}"}]},
      {"id": 12, "title": "Client 005 - Ticket Volume", "type": "timeseries", "targets": [{"expr": "parwa_tickets_total{client_id=\"client_005\"}"}]},
      {"id": 13, "title": "Accuracy Comparison", "type": "timeseries", "targets": [{"expr": "parwa_accuracy_percent", "legendFormat": "{{client_id}}"}]},
      {"id": 14, "title": "Response Time Comparison", "type": "timeseries", "targets": [{"expr": "histogram_quantile(0.95, rate(parwa_response_time_bucket[5m])) * 1000"}]},
      {"id": 15, "title": "Error Rate by Client", "type": "timeseries", "targets": [{"expr": "rate(parwa_errors_total[5m])"}]}
    ],
    "schemaVersion": 38
  }
}
