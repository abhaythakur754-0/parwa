# ── LLM API (required for AI ticket responses) ──
GOOGLE_AI_API_KEY=CHANGE_ME
CEREBRAS_API_KEY=CHANGE_ME
GROQ_API_KEY=CHANGE_ME
LLM_PRIMARY_PROVIDER=google
LLM_FALLBACK_PROVIDER=groq

# ── Email via Brevo (required for email notifications) ──
BREVO_API_KEY=CHANGE_ME
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=PARWA

# ── SMS via Twilio (required for SMS notifications) ──
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+1234567890

# ── Auth & Security ──
JWT_SECRET_KEY=CHANGE_ME-dev-jwt-secret-32-chars
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Database ──
DATABASE_URL=file:./db/custom.db
