# ── PARWA Environment Configuration ──
# Copy this file to .env and fill in the values

# Application
ENVIRONMENT=development  # development | staging | test | production
SECRET_KEY=              # Cryptographically random key (python -c "import secrets; print(secrets.token_urlsafe(32))")
DEBUG=true

# Database
DATABASE_URL=postgresql://parwa:parwa_password@localhost:5432/parwa
REDIS_URL=redis://:parwa_redis@localhost:6379/0
REDIS_PASSWORD=          # Required in production

# JWT
JWT_SECRET_KEY=          # Cryptographically random key (min 32 chars in production)
JWT_ALGORITHM=HS256      # HS256 or RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT RS256 (optional - for production)
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
JWT_KID=parwa-key-v1

# AI Providers
GOOGLE_AI_API_KEY=
CEREBRAS_API_KEY=
GROQ_API_KEY=
LLM_PRIMARY_PROVIDER=google
LLM_FALLBACK_PROVIDER=groq

# Email (Brevo)
BREVO_API_KEY=
FROM_EMAIL=noreply@parwa.ai

# SMS/Voice (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Payments (Paddle)
PADDLE_CLIENT_TOKEN=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_WEBHOOK_NOTIFICATION_SET_ID=
PADDLE_PRICE_IDS=

# Encryption
DATA_ENCRYPTION_KEY=     # Must be exactly 32 characters in production

# Storage
STORAGE_BACKEND=local    # local or gcp
STORAGE_LOCAL_PATH=./storage
GCP_STORAGE_BUCKET=

# Monitoring
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# CORS
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Celery
CELERY_BROKER_URL=redis://:parwa_redis@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:parwa_redis@localhost:6379/2

# Compliance
GDPR_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=2555

# Pricing Integrity
PRICING_SIGNING_KEY=     # Cryptographically random key (must change in production)

# MCP Server
MCP_SERVER_URL=
MCP_AUTH_TOKEN=          # Required in production

# Shopify
SHOPIFY_WEBHOOK_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# IP Allowlist
IP_ALLOWLIST_ENABLED=false
