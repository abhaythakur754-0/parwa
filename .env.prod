# ─────────────────────────────────────────────────────────────
# PARWA — Production Environment Configuration
# ─────────────────────────────────────────────────────────────
# ⚠️  COPY THIS FILE TO .env.prod AND FILL IN REAL VALUES
# NEVER commit .env.prod to Git!
# This template contains ALL variables needed for docker-compose.prod.yml

# ─── APPLICATION ─────────────────────────────────────────────
ENVIRONMENT=production
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
DEBUG=false

# ─── DATABASE (Docker PostgreSQL) ────────────────────────────
POSTGRES_USER=parwa
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=parwa_db
DATABASE_URL=postgresql+asyncpg://parwa:CHANGE_ME_strong_db_password@db:5432/parwa_db
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/0
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ─── CELERY ──────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_strong_redis_password@redis:6379/2

# ─── LLM APIs ────────────────────────────────────────────────
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here
GROQ_API_KEY=your_groq_api_key_here
LLM_PRIMARY_PROVIDER=google
LLM_FALLBACK_PROVIDER=groq

# ─── EMAIL (Brevo) ───────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
FROM_EMAIL=noreply@parwa.ai

# ─── SMS/VOICE (Twilio) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
TWILIO_API_KEY=your_twilio_api_key_here
TWILIO_VOICE_WEBHOOK_URL=https://parwa.ai/webhooks/voice

# ─── PAYMENTS (Paddle) ──────────────────────────────────────
PADDLE_CLIENT_TOKEN=your_paddle_client_token_here
PADDLE_API_KEY=your_paddle_api_key_here
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret_here

# ─── COMPLIANCE ──────────────────────────────────────────────
GDPR_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=2555
DATA_ENCRYPTION_KEY=CHANGE_ME_exactly_32_chars_long_enc_key

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── GOOGLE OAUTH ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=https://parwa.ai,https://www.parwa.ai

# ─── FRONTEND ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://parwa.ai
NEXT_PUBLIC_PADDLE_KEY=your_paddle_public_key_here

# ─── MONITORING ──────────────────────────────────────────────
SENTRY_DSN=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password
GRAFANA_API_KEY=

# ─── GCP STORAGE ─────────────────────────────────────────────
GCP_STORAGE_BUCKET=your_gcp_bucket_name_here

# ─── MCP SERVER ──────────────────────────────────────────────
MCP_SERVER_URL=http://mcp:8080
MCP_AUTH_TOKEN=CHANGE_ME_mcp_auth_token

# ─── FEATURE FLAGS ───────────────────────────────────────────
FEATURE_FLAGS_PATH=feature_flags
TRAINING_THRESHOLD=50

# ─── DEPLOYMENT ──────────────────────────────────────────────
VERSION=latest
