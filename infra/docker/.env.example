# ════════════════════════════════════════════════════════════════
# PARWA — Production Environment Variables
# Copy to .env and fill in values before deployment
# ════════════════════════════════════════════════════════════════

# PostgreSQL
POSTGRES_PASSWORD=your-secure-postgres-password-here
POSTGRES_DB=parwa
POSTGRES_USER=parwa

# Redis
REDIS_PASSWORD=your-secure-redis-password-here

# Application Security
SECRET_KEY=your-secret-key-min-32-characters-long

# OpenAI / LLM API Keys
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Paddle (Payment Processing)
PADDLE_API_KEY=pdl_live_your-paddle-api-key
PADDLE_WEBHOOK_SECRET=pdl_whs_your-webhook-secret

# Email Service (SendGrid/Mailgun)
SENDGRID_API_KEY=SG.your-sendgrid-key
EMAIL_FROM=noreply@parwa.ai

# Twilio (Voice/SMS)
TWILIO_ACCOUNT_SID=ACyour-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Monitoring (Sentry)
SENTRY_DSN=https://xxx@sentry.io/xxx

# Feature Flags
ENABLE_VOICE=false
ENABLE_SMS=false
ENABLE_ANALYTICS=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Session
SESSION_EXPIRE_HOURS=24
