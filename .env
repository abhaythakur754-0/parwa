# ════════════════════════════════════════════════════════════════
# PARWA — Docker Development Environment
# ════════════════════════════════════════════════════════════════
# IMPORTANT: Replace placeholder values with your actual keys!
# NEVER commit this file to production!

# ─── APPLICATION ─────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=dev-secret-key-change-in-production-32ch
DEBUG=true

# ─── DATABASE (Docker PostgreSQL) ────────────────────────────
POSTGRES_USER=parwa
POSTGRES_PASSWORD=parwa_dev
POSTGRES_DB=parwa_db
DATABASE_URL=postgresql://parwa:parwa_dev@localhost:5432/parwa_db
REDIS_URL=redis://localhost:6379/0

# ─── JWT (BC-011) ──────────────────────────────────────────
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-prod-32c

# ─── COMPLIANCE ──────────────────────────────────────────────
DATA_ENCRYPTION_KEY=dev-encryption-key-32-chars-exactly!!

# ─── LLM APIs ────────────────────────────────────────────────
# Add your actual API keys below:
GOOGLE_AI_API_KEY=
CEREBRAS_API_KEY=
GROQ_API_KEY=
LLM_PRIMARY_PROVIDER=google
LLM_FALLBACK_PROVIDER=groq

# ─── EMAIL (Brevo) ───────────────────────────────────────────
BREVO_API_KEY=
FROM_EMAIL=noreply@parwa.ai

# ─── SMS/VOICE (Twilio) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── PAYMENTS (Paddle) ───────────────────────────────────────
PADDLE_CLIENT_TOKEN=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── CELERY ──────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── NEXT.JS ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_PADDLE_KEY=
