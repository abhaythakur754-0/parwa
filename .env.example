# ─────────────────────────────────────────────────────────────
# PARWA Environment Configuration Template
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to Git - it contains sensitive keys!

# ─── APPLICATION ─────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=your_secret_key_here
DEBUG=true

# ─── DATABASE (Docker PostgreSQL) ────────────────────────────
POSTGRES_USER=parwa
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=parwa_db
DATABASE_URL=postgresql://parwa:your_password@localhost:5432/parwa_db
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ─── LLM APIs ────────────────────────────────────────────────
# Google AI Studio (Primary) - https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Cerebras (Fast Inference) - https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Groq (Alternative Fast) - https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# LLM Provider Selection (google, cerebras, or groq)
LLM_PRIMARY_PROVIDER=google
LLM_FALLBACK_PROVIDER=groq

# ─── EMAIL (Brevo) ───────────────────────────────────────────
# Get your API key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here
FROM_EMAIL=noreply@yourdomain.com

# ─── SMS/VOICE (Twilio) ──────────────────────────────────────
# Get your credentials at: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
TWILIO_API_KEY=your_twilio_api_key_here
TWILIO_VOICE_WEBHOOK_URL=https://yourdomain.com/webhooks/voice

# ─── PAYMENTS (Paddle ONLY) ─────────────────────────────────
# Get your API keys at: https://vendors.paddle.com/authentication
PADDLE_CLIENT_TOKEN=your_paddle_client_token_here
PADDLE_API_KEY=your_paddle_api_key_here
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret_here

# ─── COMPLIANCE ──────────────────────────────────────────────
GDPR_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=2555
DATA_ENCRYPTION_KEY=your_32_character_encryption_key_here

# ─── FEATURE FLAGS ───────────────────────────────────────────
FEATURE_FLAGS_PATH=feature_flags

# ─── DSPy (F-061) ──────────────────────────────────────────
# Enable DSPy prompt/response optimization in the AI pipeline.
# When false (default), the pipeline works exactly as before.
# When true, DSPy intercepts the response after generation but
# before the CLARA quality gate for optimization.
DSPY_ENABLED=false

# ─── AGENT LIGHTNING ─────────────────────────────────────────
TRAINING_THRESHOLD=50

# ─── JWT (BC-011) ──────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key_here
REFRESH_TOKEN_PEPPER=your_refresh_token_pepper_here

# ─── GOOGLE OAUTH ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://parwa.ai

# ─── CELERY (Week 3: BC-004) ──────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── GCP STORAGE ──────────────────────────────────────────
GCP_STORAGE_BUCKET=your_gcp_bucket_name_here

# ─── MONITORING ───────────────────────────────────────────
SENTRY_DSN=
GRAFANA_API_KEY=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password_here

# ─── SENTRY (Frontend) ──────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ENVIRONMENT=production

# ─── MCP SERVER ───────────────────────────────────────────
MCP_SERVER_URL=http://localhost:5100
MCP_AUTH_TOKEN=your_mcp_token_here

# ─── NEXT.JS ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_PADDLE_KEY=your_paddle_public_key_here

# ─── DEPLOYMENT ──────────────────────────────────────────
VERSION=latest
