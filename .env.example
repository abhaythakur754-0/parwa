# ═════════════════════════════════════════════════════════════
#                    PARWA API KEYS
#          Copy this file to .env and fill in values
# ═════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=your-secret-key-change-in-production
DEBUG=true

# ─────────────────────────────────────────────────────────────
# DATABASE (Docker - No external API needed)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://parwa:parwa_dev@localhost:5432/parwa_db
REDIS_URL=redis://localhost:6379/0
POSTGRES_USER=parwa
POSTGRES_PASSWORD=parwa_dev
POSTGRES_DB=parwa_db

# ─────────────────────────────────────────────────────────────
# LLM APIs
# ─────────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=your_google_ai_key
CEREBRAS_API_KEY=your_cerebras_key
GROQ_API_KEY=your_groq_key

# ─────────────────────────────────────────────────────────────
# PAYMENT
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# ─────────────────────────────────────────────────────────────
# SMS/VOICE
# ─────────────────────────────────────────────────────────────
BIRD_API_KEY=your_bird_key
BIRD_ACCESS_KEY=your_bird_access_key

# ─────────────────────────────────────────────────────────────
# EMAIL
# ─────────────────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_key
FROM_EMAIL=noreply@parwa.ai

# ═════════════════════════════════════════════════════════════
